menu "FDC2214Cap"

config FDC2214CAP_ENABLE
    bool "Enable FDC2214Cap component"
    default y

config FDC2214CAP_LOG_LEVEL
    int "Log level (0=none, 4=verbose)"
    range 0 4
    default 3
    depends on FDC2214CAP_ENABLE

config FDC2214CAP_I2C_ADDR
    hex "I2C address (0x2A or 0x2B)"
    default 0x2A

config FDC2214CAP_CHANNELS
    int "Number of channels used (1 or 2)"
    default 2
    range 1 2


endmenu
